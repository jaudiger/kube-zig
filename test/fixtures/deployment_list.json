{
  "apiVersion": "apps/v1",
  "kind": "DeploymentList",
  "metadata": {
    "resourceVersion": "67890"
  },
  "items": [
    {
      "apiVersion": "apps/v1",
      "kind": "Deployment",
      "metadata": {
        "name": "my-deploy",
        "namespace": "default"
      },
      "spec": {
        "replicas": 2,
        "selector": {
          "matchLabels": {
            "app": "myapp"
          }
        },
        "template": {
          "spec": {
            "containers": [
              {
                "name": "app",
                "image": "myapp:latest"
              }
            ]
          }
        }
      }
    }
  ]
}
